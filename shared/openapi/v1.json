      "XypPayloadIn": {
        "additionalProperties": true,
        "description": "Raw XYP response the client captured on a successful on-device lookup.\n\nThe client MUST pass this through untouched so we can store it verbatim\nin `vehicles.raw_xyp` for later auditing. Individual fields below are\nparsed from this payload during registration.\n\nField names match smartcar.mn's real wire format — camelCase upstream,\nwhich is why each line ignores `N815` (non-lowercase variable names).",
        "properties": {
          "buildYear": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Buildyear"
          },
          "cabinNumber": {
            "anyOf": [
