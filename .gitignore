# ---------------------------------------------------------------------------
# iAuto — root .gitignore
# ---------------------------------------------------------------------------

# -- Secrets & local env ----------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key

# -- Python / backend -------------------------------------------------------
venv/
.venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
dist/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/
.python-version

# -- Alembic local state ----------------------------------------------------
backend/alembic/versions/*.pyc

# -- Node / mobile / shared -------------------------------------------------
node_modules/
.pnpm-store/
.expo/
.expo-shared/
dist-mobile/
*.tsbuildinfo

# -- ML artifacts -----------------------------------------------------------
ml/artifacts/
ml/data/
*.ckpt
*.pt
*.onnx
*.cbm
mlruns/

# -- Docker / infra local state ---------------------------------------------
infra/.local/
infra/data/

# -- IDE / OS ---------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# -- Misc -------------------------------------------------------------------
*.log
logs/
tmp/
.scratch/

# Claude
.claude/
tasks/
CLAUDE.md

# VSCodeCounter
.VSCodeCounter/

_design_source/
# Smoke / scratch artefacts (generated during local testing)
.iauto_token
.iauto_biz_token
.iauto_assets
.biz_verify.json
.dr_verify.json
.tmp_reg_body.json
.warning.png
.engine.wav
