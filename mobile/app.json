{
  "expo": {
    "name": "UCar",
    "slug": "iauto",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "iauto",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "mn.iauto.app",
      "infoPlist": {
        "NSCameraUsageDescription": "UCar camera-аар хийн шил, хохирол, хэсэг танихад хэрэглэнэ.",
        "NSMicrophoneUsageDescription": "AI Механикт хөдөлгүүрийн чимээ бичих, дуу хоолойгоор асуухад хэрэглэнэ.",
        "NSPhotoLibraryUsageDescription": "Зах зээл, Сошиал постонд зураг оруулахад хэрэглэнэ."
      }
    },
    "android": {
      "package": "mn.iauto.app",
      "adaptiveIcon": {
        "backgroundColor": "#050816",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "UCar-д зургаа сонгож оруулахад хэрэглэнэ.",
          "cameraPermission": "UCar camera-аар зураг авахад хэрэглэнэ."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "AI Механикт хөдөлгүүрийн чимээ + дуу хоолой бичихэд хэрэглэнэ."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#050816",
          "dark": {
            "backgroundColor": "#050816"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiBaseUrl": "https://api.ucar.mn",
      "apiBaseUrlIos": "https://api.ucar.mn",
      "apiBaseUrlWeb": "https://api.ucar.mn"
    }
  }
}
