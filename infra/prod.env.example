# Production env template — copy to /opt/iauto/.env on the host and
# fill in the real values before `docker compose up`. NEVER commit a
# filled copy of this file to git.
#
# Generate the crypto keys with:
#   python -c "import secrets; print(secrets.token_hex(32))"          # APP_SEARCH_KEY, JWT_SECRET
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"  # APP_DATA_KEY

# --- compose-only ---
IAUTO_IMAGE_TAG=latest

# --- core auth + crypto (REQUIRED) ---
JWT_SECRET=
APP_DATA_KEY=
APP_SEARCH_KEY=

# --- Postgres + MinIO root creds (REQUIRED) ---
POSTGRES_PASSWORD=
MINIO_ROOT_USER=iauto
MINIO_ROOT_PASSWORD=

# --- Mongolian SMS gateway ---
MESSAGEPRO_BASE_URL=https://api.messagepro.mn
MESSAGEPRO_API_KEY=
MESSAGEPRO_SENDER=
OPERATOR_PHONE=

# --- QPay v2 (production) ---
QPAY_BASE_URL=https://merchant.qpay.mn
QPAY_USERNAME=
QPAY_PASSWORD=
QPAY_INVOICE_CODE=
QPAY_CALLBACK_URL=https://api.iauto.mn/v1/payments/qpay/callback

# --- AI Mechanic (Phase 3) ---
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- Observability (Phase 5) ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
