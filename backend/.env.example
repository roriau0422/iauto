# iAuto backend — environment template.
# Copy to backend/.env and fill in real values. backend/.env is git-ignored.

# ---- Runtime ---------------------------------------------------------------
APP_ENV=dev                    # dev | staging | prod
APP_DEBUG=true
APP_NAME=iauto-backend
APP_LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
APP_LOG_FORMAT=console          # console | json

# ---- HTTP ------------------------------------------------------------------
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
HTTP_CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# ---- Database --------------------------------------------------------------
# Points at the docker-compose Postgres mapped on host port 15432.
DATABASE_URL=postgresql+asyncpg://iauto:iauto_dev@localhost:15432/iauto
DATABASE_TEST_URL=postgresql+asyncpg://iauto:iauto_dev@localhost:15432/iauto_test
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# ---- Redis -----------------------------------------------------------------
REDIS_URL=redis://localhost:16379/0

# ---- Object storage (MinIO locally, S3 in prod) ----------------------------
S3_ENDPOINT_URL=http://localhost:19000
S3_ACCESS_KEY=iauto
S3_SECRET_KEY=iauto_dev_minio
S3_REGION=us-east-1
S3_BUCKET_MEDIA=iauto-media
S3_USE_PATH_STYLE=true

# ---- Auth / JWT ------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-48-byte-urlsafe-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
JWT_ISSUER=iauto

# ---- Column-level encryption (users.phone, vehicles.vin/plate) -----------
# Both required — the app will NOT start if either is missing.
# Rotating these requires a re-encryption migration and key-version scheme —
# treat as immutable for now. Do NOT commit real values to git.
#
# APP_DATA_KEY    — Fernet key (44-char base64-urlsafe). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# APP_SEARCH_KEY  — HMAC-SHA256 key (64-char hex). Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
APP_DATA_KEY=change-me-fernet-urlsafe-b64-44-chars
APP_SEARCH_KEY=change-me-64-hex-chars

# ---- OTP -------------------------------------------------------------------
OTP_TTL_SECONDS=300             # 5 min
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# ---- SMS provider ----------------------------------------------------------
# SMS_PROVIDER = console (logs OTP to stdout) | messagepro (real send)
SMS_PROVIDER=console
MESSAGEPRO_BASE_URL=https://api.messagepro.mn
MESSAGEPRO_API_KEY=replace-with-real-key
MESSAGEPRO_SENDER=72017701

# ---- Operator pager --------------------------------------------------------
# Phone that receives backend-generated outage SMS (e.g. smartcar.mn XYP
# gateway errors reported by mobile clients). Leave blank to disable alerts.
OPERATOR_PHONE=
XYP_ALERT_WINDOW_SECONDS=900

# ---- Admin panel (section H, later session) --------------------------------
ADMIN_PANEL_ENABLED=false
ADMIN_PANEL_SECRET=change-me

# ---- Observability ---------------------------------------------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ---- QPay (Phase 1 session 7) ----------------------------------------------
# Payment rail. v2 API docs: https://developer.qpay.mn/
# Sandbox base: https://merchant-sandbox.qpay.mn
# Prod base:    https://merchant.qpay.mn
# Credentials are issued per merchant; username/password do Basic auth against
# /v2/auth/token which returns a bearer for /v2/invoice + /v2/payment/check.
# QPAY_INVOICE_CODE is the merchant's registered invoice template code.
# QPAY_CALLBACK_URL is the public HTTPS URL QPay will POST to on payment.
QPAY_BASE_URL=https://merchant.qpay.mn
QPAY_USERNAME=replace-with-merchant-username
QPAY_PASSWORD=replace-with-merchant-password
QPAY_INVOICE_CODE=replace-with-invoice-template-code
QPAY_CALLBACK_URL=
